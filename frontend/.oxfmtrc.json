{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["dist/**", "src/components/ui/**", "src/gen/**", "src/routeTree.gen.ts"],
  "printWidth": 100,
  "semi": false,
  "singleQuote": false,
  "sortImports": true,
  "sortTailwindcss": {
    "functions": ["cn", "cva"],
    "stylesheet": "./src/index.css"
  },
  "trailingComma": "all"
}
